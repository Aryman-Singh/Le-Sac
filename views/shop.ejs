<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Le-Sac | Shop</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body {
      font-family: "Helvetica Now Display", "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
  </style>
</head>

<body class="min-h-screen bg-gradient-to-br from-[#f8fafc] via-[#e0e7ff] to-[#ffffff]">

  <header class="sticky top-0 z-20 bg-white/80 backdrop-blur border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-8 h-20 flex items-center justify-between">
      <h1 class="text-2xl font-semibold text-[#1e3a8a] tracking-tight">
        Le-Sac
      </h1>

      <nav class="flex gap-8 text-slate-600">
        <a href="/" class="hover:text-[#1e3a8a] transition">Shop</a>
        <a href="#" class="hover:text-[#1e3a8a] transition">Collections</a>
        <a href="/cart" class="hover:text-[#1e3a8a] transition">Cart</a>
        <a href="#" class="hover:text-[#1e3a8a] transition">About</a>
        <a href="/users/logout" class="hover:text-[#1e3a8a] transition">logout</a>

      </nav>
    </div>
  </header>

  <section class="max-w-7xl mx-auto px-8 py-16">
    <div class="mb-12">
      <h2 class="text-4xl font-semibold tracking-tight text-[#1e3a8a]">
        Premium Collection
      </h2>
      <p class="text-slate-500 mt-3 max-w-xl">
        Discover timeless bags crafted with precision, elegance, and purpose.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <% products.forEach(product => { %>
        <div class="bg-<%= product.bgcolor %> rounded-3xl shadow-lg hover:shadow-2xl transition overflow-hidden">
          <div class="h-64 bg-slate-100">
            <img src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
          </div>
          <div class="p-6 bg-<%= product.panelcolor %>">
            <h3 class="text-lg font-semibold text-slate-800">
              <%= product.name %>
            </h3>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-xl font-semibold text-[#1e3a8a]">
                $<%= product.price %>
              </span>
              <a href="/addtocart/<%= product._id %>">
              <button
                class="px-5 py-2 rounded-xl bg-[#1e3a8a] text-white
                hover:bg-[#1d4ed8] transition">
                Add
              </button>
              </a>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </section>

  <footer class="border-t border-slate-200 mt-20">
    <div class="max-w-7xl mx-auto px-8 py-10 text-sm text-slate-500 flex justify-between">
      <span>© 2026 Le-Sac</span>
      <span>Crafted with precision</span>
    </div>
  </footer>

</body>
</html>
